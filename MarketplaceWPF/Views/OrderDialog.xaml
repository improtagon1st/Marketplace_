<Window x:Class="MarketplaceWPF.Views.OrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" 
        Height="400" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Товар -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Товар:" FontWeight="Bold" FontSize="14"/>
            <TextBlock x:Name="ProductNameText" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock x:Name="ProductPriceText" FontSize="14" Foreground="Green" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Количество -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Количество:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="QuantityBox" Text="1" FontSize="14" Height="35" Padding="5"/>
        </StackPanel>

        <!-- Выбор ПВЗ -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="Пункт выдачи:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="PickupPointCombo" 
                      FontSize="14" 
                      Height="35"
                      DisplayMemberPath="Name"/>
        </StackPanel>

        <!-- Информация о ПВЗ -->
        <Border Grid.Row="3" 
                Background="#F5F5F5" 
                Padding="15" 
                CornerRadius="5"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock x:Name="PickupAddressText" 
                           FontSize="12" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="PickupPhoneText" 
                           FontSize="12"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="PickupHoursText" 
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Отмена" 
                    Width="100" 
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Заказать" 
                    Width="100" 
                    Height="40"
                    Background="#2196F3"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="Order_Click"/>
        </StackPanel>
    </Grid>
</Window>