<Page x:Class="MarketplaceWPF.Views.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MarketplaceWPF.ViewModels"
      Title="CartPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,20">
            <TextBlock Text="🛒 Корзина" 
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="🔄 Обновить"
                    Command="{Binding RefreshCommand}"
                    Height="40"
                    Margin="20,0,0,0"
                    Padding="15,0"
                    Background="#2196F3"
                    Foreground="White"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Список товаров -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CartItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,15"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Изображение -->
                                <Border Grid.Column="0" 
                                        Width="80" 
                                        Height="80"
                                        CornerRadius="8"
                                        Background="#F5F5F5">
                                    <Image Source="{Binding ProductImage}"
                                           Stretch="Uniform"
                                           Margin="5"/>
                                </Border>

                                <!-- Информация о товаре -->
                                <StackPanel Grid.Column="1" 
                                            Margin="20,0,20,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ProductName}" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>

                                    <TextBlock FontSize="16">
                                        <Run Text="Цена: "/>
                                        <Run Text="{Binding ProductPrice}" FontWeight="Bold" Foreground="#2196F3"/>
                                        <Run Text=" руб."/>
                                    </TextBlock>

                                    <TextBlock FontSize="12" 
                                               Foreground="Gray"
                                               Margin="0,5,0,0">
                                        <Run Text="Доступно: "/>
                                        <Run Text="{Binding AvailableStock}"/>
                                        <Run Text=" шт."/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Управление количеством -->
                                <StackPanel Grid.Column="2" 
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,20,0">
                                    <Button Content="−"
                                            Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Width="35"
                                            Height="35"
                                            Background="#F44336"
                                            Foreground="White"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D32F2F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <TextBlock Text="{Binding Quantity}" 
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Margin="15,0"
                                               VerticalAlignment="Center"
                                               MinWidth="30"
                                               TextAlignment="Center"/>

                                    <Button Content="+"
                                            Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Width="35"
                                            Height="35"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#388E3C"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- Цена и удаление -->
                                <StackPanel Grid.Column="3" 
                                            VerticalAlignment="Center">
                                    <TextBlock FontSize="20" 
                                               FontWeight="Bold"
                                               Foreground="#4CAF50"
                                               TextAlignment="Right"
                                               Margin="0,0,0,10">
                                        <Run Text="{Binding TotalPrice}"/>
                                        <Run Text=" руб." FontSize="14"/>
                                    </TextBlock>

                                    <Button Content="🗑️ Удалить"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Height="35"
                                            Padding="15,0"
                                            Background="#F44336"
                                            Foreground="White"
                                            FontSize="12"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D32F2F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Итого и оформление -->
        <Border Grid.Row="2" 
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="25"
                Margin="0,20,0,0"
                Visibility="{Binding IsCheckoutVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Итоговая сумма:" 
                               FontSize="16" 
                               Foreground="Gray"
                               Margin="0,0,0,5"/>
                    <TextBlock FontSize="32" FontWeight="Bold" Foreground="#4CAF50">
                        <Run Text="{Binding TotalAmount}"/>
                        <Run Text=" руб." FontSize="20"/>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Оформить заказ"
                        Command="{Binding CheckoutCommand}"
                        Height="60"
                        Padding="40,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#388E3C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>