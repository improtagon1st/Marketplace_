<Page x:Class="MarketplaceWPF.Views.WorkerManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      
      Title="WorkerManagementPage">

    

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="👥 Управление работниками" 
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal">
                <Button Content="🔄 Обновить"
                        Command="{Binding RefreshCommand}"
                        Height="40"
                        Padding="15,0"
                        Margin="0,0,10,0"
                        Background="#2196F3"
                        Foreground="White"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1976D2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="➕ Добавить работника"
                        Command="{Binding AddWorkerCommand}"
                        Height="40"
                        Padding="15,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#388E3C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Список работников -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Workers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,15"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Иконка -->
                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="30"
                                        Background="#E3F2FD"
                                        Margin="0,0,20,0">
                                    <TextBlock Text="👤" 
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Информация -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FullName}" 
                                               FontSize="18" 
                                               FontWeight="Bold"
                                               Margin="0,0,0,5"/>

                                    <TextBlock FontSize="14" 
                                               Foreground="#666"
                                               Margin="0,0,0,3">
                                        <Run Text="📧"/>
                                        <Run Text="{Binding Email}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="14" 
                                               Foreground="#666"
                                               Margin="0,0,0,3">
                                        <Run Text="📱"/>
                                        <Run Text="{Binding Phone}"/>
                                    </TextBlock>

                                    <Border Background="#E8F5E9"
                                            CornerRadius="5"
                                            Padding="8,4"
                                            HorizontalAlignment="Left"
                                            Margin="0,5,0,0">
                                        <TextBlock FontSize="13" 
                                                   Foreground="#2E7D32"
                                                   FontWeight="Bold">
                                            <Run Text="📍"/>
                                            <Run Text="{Binding PickupPointName}"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <!-- Кнопки действий -->
                                <StackPanel Grid.Column="2" 
                                            VerticalAlignment="Center">
                                    <Button Content="✏️ Изменить"
                                            Command="{Binding DataContext.EditWorkerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Width="120"
                                            Height="35"
                                            Margin="0,0,0,10"
                                            Background="#2196F3"
                                            Foreground="White"
                                            FontSize="13"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1976D2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="🗑️ Удалить"
                                            Command="{Binding DataContext.DeleteWorkerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Width="120"
                                            Height="35"
                                            Background="#F44336"
                                            Foreground="White"
                                            FontSize="13"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D32F2F"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>