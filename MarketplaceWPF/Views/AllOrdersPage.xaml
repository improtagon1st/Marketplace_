<Page x:Class="MarketplaceWPF.Views.AllOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MarketplaceWPF.ViewModels"
      xmlns:local="clr-namespace:MarketplaceWPF.Helpers"
      Title="AllOrdersPage">

    <Page.Resources>
        <Style x:Key="FilterRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="15,8">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,20">
            <TextBlock Text="📊 Все заказы" 
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Content="🔄 Обновить"
                    Command="{Binding RefreshCommand}"
                    Height="40"
                    Margin="20,0,0,0"
                    Padding="15,0"
                    Background="#2196F3"
                    Foreground="White"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Фильтр по ПВЗ -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Пункт выдачи:" 
                       FontSize="14" 
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding PickupPoints}"
                      SelectedItem="{Binding SelectedPickupPoint}"
                      DisplayMemberPath="Name"
                      FontSize="14"
                      Height="40"
                      Width="300"
                      HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Фильтры по статусу -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,20">
            <RadioButton Content="Все" 
                         GroupName="FilterGroup"
                         Tag="All"
                         Checked="Filter_Changed"
                         Style="{StaticResource FilterRadioButtonStyle}"
                         IsChecked="True"/>

            <RadioButton Content="⏳ Созданные" 
                         GroupName="FilterGroup"
                         Tag="Created"
                         Checked="Filter_Changed"
                         Style="{StaticResource FilterRadioButtonStyle}"
                         Margin="10,0,0,0"/>

            <RadioButton Content="📦 Доставленные" 
                         GroupName="FilterGroup"
                         Tag="Delivered"
                         Checked="Filter_Changed"
                         Style="{StaticResource FilterRadioButtonStyle}"
                         Margin="10,0,0,0"/>

            <RadioButton Content="✅ Выданные" 
                         GroupName="FilterGroup"
                         Tag="PickedUp"
                         Checked="Filter_Changed"
                         Style="{StaticResource FilterRadioButtonStyle}"
                         Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Список заказов -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Orders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,15"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Информация о заказе -->
                                <StackPanel Grid.Column="0">
                                    <!-- Заголовок -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock FontSize="20" FontWeight="Bold">
                                            <Run Text="Заказ #"/>
                                            <Run Text="{Binding Id}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                                   FontSize="14" 
                                                   Foreground="Gray"
                                                   Margin="15,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Статус -->
                                    <Border Width="200" 
                                            Height="30"
                                            CornerRadius="15"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,15">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Created">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="PickedUp">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Created">
                                                            <Setter Property="Text" Value="⏳ Создан"/>
                                                            <Setter Property="Foreground" Value="#F57C00"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                            <Setter Property="Text" Value="📦 Доставлен"/>
                                                            <Setter Property="Foreground" Value="#1976D2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="PickedUp">
                                                            <Setter Property="Text" Value="✅ Получен"/>
                                                            <Setter Property="Foreground" Value="#388E3C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Клиент -->
                                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                            <TextBlock Text="👤 Клиент" 
                                                       FontSize="12" 
                                                       Foreground="Gray"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding CustomerName}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding CustomerPhone}" 
                                                       FontSize="12" 
                                                       Foreground="Gray"/>
                                        </StackPanel>

                                        <!-- ПВЗ -->
                                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                            <TextBlock Text="📍 ПВЗ" 
                                                       FontSize="12" 
                                                       Foreground="Gray"
                                                       Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding PickupPointName}" 
                                                       FontSize="14" 
                                                       FontWeight="Bold"/>
                                        </StackPanel>

                                        <!-- Товары -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="📦 Товары" 
                                                       FontSize="12" 
                                                       Foreground="Gray"
                                                       Margin="0,0,0,5"/>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="12">
                                                            <Run Text="{Binding ProductName}"/>
                                                            <Run Text=" ×"/>
                                                            <Run Text="{Binding Quantity}" FontWeight="Bold"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Сумма -->
                                    <TextBlock FontSize="18" 
                                               FontWeight="Bold"
                                               Margin="0,15,0,0">
                                        <Run Text="Итого:"/>
                                        <Run Text="{Binding TotalPrice}" Foreground="Green"/>
                                        <Run Text=" руб." Foreground="Green"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- QR-код -->
                                <Button Grid.Column="1"
                                        Content="Показать QR"
                                        Command="{Binding DataContext.ShowQRCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Width="140"
                                        Height="45"
                                        VerticalAlignment="Center"
                                        Background="#2196F3"
                                        Foreground="White"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                CornerRadius="8">
                                                            <ContentPresenter HorizontalAlignment="Center" 
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1976D2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>