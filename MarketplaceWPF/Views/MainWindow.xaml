<Window x:Class="MarketplaceWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Маркетплейс" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Стиль для кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="#2196F3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Верхняя часть с меню -->
                <StackPanel Grid.Row="0">
                    <!-- Заголовок -->
                    <Border Background="#1976D2" Height="80" Padding="15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🛒 Маркетплейс" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                            <TextBlock x:Name="UserNameText"
                               FontSize="12" 
                               Foreground="White" 
                               Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Меню для Customer -->
                    <StackPanel x:Name="CustomerMenu" Visibility="Collapsed">
                        <Button Content="📦 Каталог товаров" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowCatalog_Click"/>
                        <Button Content="🛍️ Мои заказы" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowOrders_Click"/>
                        <Button Content="👤 Профиль" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowProfile_Click"/>
                    </StackPanel>

                    <!-- Меню для Worker -->
                    <StackPanel x:Name="WorkerMenu" Visibility="Collapsed">
                        <Button Content="📋 Заказы на ПВЗ" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowPickupOrders_Click"/>
                        <Button Content="🔍 Сканировать QR" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowScanQR_Click"/>
                    </StackPanel>

                    <!-- Меню для Admin -->
                    <StackPanel x:Name="AdminMenu" Visibility="Collapsed">
                        <Button Content="📦 Управление товарами" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowProducts_Click"/>
                        <Button Content="📂 Категории" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowCategories_Click"/>
                        <Button Content="📍 Пункты выдачи" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowPickupPoints_Click"/>
                        <Button Content="📊 Все заказы" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="ShowAllOrders_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопка выхода внизу -->
                <Button Grid.Row="1"
                Content="🚪 Выход" 
                Style="{StaticResource MenuButtonStyle}" 
                Click="Logout_Click"/>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Frame x:Name="ContentFrame" 
               Grid.Column="1" 
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>