<Window x:Class="MarketplaceWPF.Views.ProductEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" 
        Height="500" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   x:Name="TitleText"
                   Text="Добавить товар" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Название -->
                <TextBlock Text="Название товара" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="NameBox"
                         FontSize="14"
                         Height="40"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Описание -->
                <TextBlock Text="Описание" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionBox"
                         FontSize="14"
                         Height="80"
                         Padding="10"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,15"/>

                <!-- Цена -->
                <TextBlock Text="Цена (руб.)" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="PriceBox"
                         FontSize="14"
                         Height="40"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Количество на складе -->
                <TextBlock Text="Количество на складе" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="StockBox"
                         FontSize="14"
                         Height="40"
                         Padding="10"
                         Margin="0,0,0,15"/>

                <!-- Категория -->
                <TextBlock Text="Категория" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryCombo"
                          FontSize="14"
                          Height="40"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          Margin="0,0,0,15"/>

                <!-- URL изображения -->
                <TextBlock Text="URL изображения (опционально)" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="ImageUrlBox"
                         FontSize="14"
                         Height="40"
                         Padding="10"
                         Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Отмена"
                    Width="100"
                    Height="45"
                    Margin="0,0,15,0"
                    Background="Transparent"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    FontSize="14"
                    Cursor="Hand"
                    Click="Cancel_Click"/>

            <Button Content="Сохранить"
                    Width="120"
                    Height="45"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Save_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>