<Page x:Class="MarketplaceWPF.Views.PickupWorkerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MarketplaceWPF.ViewModels"
      Title="PickupWorkerPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:PickupWorkerViewModel/>
    </Page.DataContext>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="🔍 Выдача заказов" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

        <!-- Поиск по QR -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="10"
                Padding="30"
                Margin="0,0,0,30">
            <StackPanel>
                <TextBlock Text="Введите код заказа или отсканируйте QR-код" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding QRCode, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Height="50"
                             Padding="15"
                             VerticalContentAlignment="Center"
                             Margin="0,0,15,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchOrderCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1"
                            Content="Найти заказ"
                            Command="{Binding SearchOrderCommand}"
                            Width="150"
                            Height="50"
                            Background="#2196F3"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1976D2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Результат поиска -->
        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="10"
                Padding="30"
                Visibility="{Binding IsOrderFound, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock FontSize="24" FontWeight="Bold">
                        <Run Text="Заказ #"/>
                        <Run Text="{Binding FoundOrder.Id}"/>
                    </TextBlock>

                    <!-- Статус -->
                    <Border Width="250" 
                            Height="35"
                            CornerRadius="18"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FoundOrder.Status}" Value="Created">
                                        <Setter Property="Background" Value="#FFF3E0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FoundOrder.Status}" Value="Delivered">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FoundOrder.Status}" Value="PickedUp">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FoundOrder.Status}" Value="Created">
                                            <Setter Property="Text" Value="⏳ Ожидает доставки"/>
                                            <Setter Property="Foreground" Value="#F57C00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FoundOrder.Status}" Value="Delivered">
                                            <Setter Property="Text" Value="✅ Готов к выдаче"/>
                                            <Setter Property="Foreground" Value="#1976D2"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding FoundOrder.Status}" Value="PickedUp">
                                            <Setter Property="Text" Value="✅ Уже выдан"/>
                                            <Setter Property="Foreground" Value="#388E3C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Детали -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Клиент -->
                        <Border Background="#F5F5F5" 
                                Padding="15" 
                                CornerRadius="8"
                                Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="👤 Клиент" 
                                           FontSize="14" 
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding FoundOrder.CustomerName}" 
                                           FontSize="16"/>
                                <TextBlock Text="{Binding FoundOrder.CustomerPhone}" 
                                           FontSize="14" 
                                           Foreground="Gray"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Товары -->
                        <TextBlock Text="📦 Товары в заказе:" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding FoundOrder.Items}" 
                                      Margin="0,0,0,15">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5" 
                                            Padding="15" 
                                            CornerRadius="8"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ProductName}" 
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                       FontSize="14"
                                                       Margin="15,0"
                                                       VerticalAlignment="Center">
                                                <Run Text="×"/>
                                                <Run Text="{Binding Quantity}" FontWeight="Bold"/>
                                            </TextBlock>

                                            <TextBlock Grid.Column="2"
                                                       FontSize="16" 
                                                       FontWeight="Bold"
                                                       Foreground="Green"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding PriceAtOrder}"/>
                                                <Run Text=" руб."/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Итого -->
                        <Border Background="#E3F2FD" 
                                Padding="15" 
                                CornerRadius="8">
                            <TextBlock FontSize="20" 
                                       FontWeight="Bold">
                                <Run Text="Итого к оплате:"/>
                                <Run Text="{Binding FoundOrder.TotalPrice}" Foreground="#1976D2"/>
                                <Run Text=" руб." Foreground="#1976D2"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки -->
                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button Content="Отмена"
                            Command="{Binding ClearCommand}"
                            Width="120"
                            Height="50"
                            Margin="0,0,15,0"
                            Background="Transparent"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            FontSize="16"
                            Cursor="Hand"/>

                    <Button Content="Выдать заказ"
                            Command="{Binding PickupOrderCommand}"
                            Width="180"
                            Height="50"
                            Background="#4CAF50"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding FoundOrder.Status}" Value="PickedUp">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Background" Value="Gray"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

   
</Page>